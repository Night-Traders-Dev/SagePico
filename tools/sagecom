#!/bin/bash
# sagecom — Sage Serial Terminal for SagePico
# Prefers native binary at /usr/local/bin/sagecom.native, falls back to interpreter

SAGECOM_NATIVE="/usr/local/bin/sagecom.native"
SAGECOM_SRC="/home/kraken/Devel/SagePico/src/tools/sage/sagecom.sage"
SAGE="/home/kraken/Devel/SagePico/deps/sagelang/sage"

# Prefer native binary if it exists
if [ -x "$SAGECOM_NATIVE" ]; then
    exec "$SAGECOM_NATIVE" "$@"
fi

# Fall back to Sage interpreter
if [ ! -f "$SAGE" ]; then
    SAGE="$(which sage 2>/dev/null)"
fi
if [ ! -f "$SAGE" ]; then
    echo "sagecom: cannot find Sage interpreter" >&2
    exit 1
fi
if [ ! -f "$SAGECOM_SRC" ]; then
    echo "sagecom: cannot find sagecom.sage at $SAGECOM_SRC" >&2
    exit 1
fi

exec "$SAGE" "$SAGECOM_SRC" "$@"
